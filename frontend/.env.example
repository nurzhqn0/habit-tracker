# Host dev overrides for `npm run dev`.
# Nuxt reads this file from the frontend/ dir — NOT the repo-root .env.
# Copy to frontend/.env and fill in.

# Relative base so the browser calls the SAME origin. Required when serving the
# dev server behind an HTTPS tunnel (Telegram Web Login / Mini App need https).
# The dev server proxies /api to the Dockerized api (see $development in
# nuxt.config.ts). For plain http://localhost:3000 this also works.
NUXT_PUBLIC_API_BASE=/api/v1
# SSR-side base — the Nuxt server (on the host) talks to the Docker api directly.
NUXT_API_INTERNAL_BASE=http://localhost:8000/api/v1

# Telegram bot username (no @) — powers the login button and Open-app links.
# Use your DEV bot's username; must match BOT_USERNAME in the repo-root .env.
NUXT_PUBLIC_BOT_USERNAME=your_dev_bot_username

# Your Telegram username — shows the Admin nav item. UI gating only; the backend
# ADMIN_USERNAME check is the real authorization.
NUXT_PUBLIC_ADMIN_USERNAME=your_telegram_username
