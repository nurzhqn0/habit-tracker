# --- Backend ---
# "production" (default) enforces a strong JWT_SECRET and disables /docs + TEST_MODE.
# Local development: set ENVIRONMENT=development (the Makefile targets do this for you).
ENVIRONMENT=production
DATABASE_URL=sqlite+aiosqlite:///./data/habitflow.db
# Required in production: at least 32 chars, e.g. `openssl rand -hex 32`
JWT_SECRET=change-me-to-a-random-256-bit-string
BOT_TOKEN=123456:your-telegram-bot-token
BOT_USERNAME=your_bot_username
# Public origin of the frontend (CORS + invite links), e.g. https://habitflow.example.com
FRONTEND_ORIGIN=http://localhost
TEST_MODE=false

# --- Frontend (nuxt runtimeConfig overrides, only needed outside docker compose) ---
NUXT_PUBLIC_API_BASE=http://localhost:8000/api/v1
NUXT_PUBLIC_BOT_USERNAME=your_bot_username
